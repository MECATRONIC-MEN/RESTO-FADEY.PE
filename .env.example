# =============================================================================
# VERCEL — Proyecto PLATAFORMA WEB (este repo)
# Fase actual: pruebas de vinculación con demo POS (también en Vercel)
# =============================================================================

# Auth
AUTH_SECRET=
# En pruebas usa la URL de Vercel; en producción: https://restofadey.pe
AUTH_URL=https://tu-plataforma.vercel.app
NEXT_PUBLIC_PLATFORM_URL=https://tu-plataforma.vercel.app

# Supabase (opcional en pruebas = usuarios demo en memoria)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Vinculación POS Render ↔ panel (misma clave en cada POS y aquí)
API_SECRET_KEY=
JWT_SECRET=

# Fallback si el cliente no tiene render_url en Supabase
NEXT_PUBLIC_POS_URL=https://tu-pos.onrender.com

# En desarrollo: permite clientId desconocido → cliente demo
# ALLOW_DEMO_CLIENT_FALLBACK=true

# Demo clientId (seed Supabase): b0000001-0000-4000-8000-000000000001

# TikTok Ads — Events API (server-side, NO subir el token a Git)
# Generar en TikTok Ads Manager → Eventos → Configuración → Generar token de acceso
TIKTOK_ACCESS_TOKEN=
# Opcional si cambia; por defecto usa el píxel D8ITO23C77U6H4V47SL0 del código
TIKTOK_PIXEL_ID=D8ITO23C77U6H4V47SL0

# --- Variables en cada POS (Render), no en Vercel ---
# CLIENT_ID=<uuid del cliente en panel admin>
# CENTRAL_API_URL=https://restofadey.pe
# API_SECRET_KEY=<misma que arriba>
# En cada request: header X-Client-Id: {CLIENT_ID}
